{
  "expo": {
    "name": "SeenSnap",
    "slug": "seensnap",
    "owner": "gregtusar",
    "scheme": "seensnap",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/branding/seensnap-logo.png",
    "splash": {
      "image": "./assets/branding/seensnap-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#0b1424"
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiBaseUrl": "http://192.168.1.188:8000/api/v1"
    },
    "ios": {
      "bundleIdentifier": "com.seensnap.app"
    },
    "android": {
      "package": "com.seensnap.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/branding/seensnap-logo.png",
        "backgroundColor": "#0b1424"
      }
    }
  }
}
